# =====================================================
# FlowStudio AI — Environment Variables
# =====================================================
# Este arquivo declara APENAS infra/secrets.
#
# A identidade do studio (nome, slogan, cores, logo,
# endereco, horarios, conteudo) NAO vive aqui.
# Vive em: src/sites/<studio>/config/
#
# Para criar um novo studio, copie src/sites/ruah/
# como template e edite os arquivos de config.
# =====================================================

# -------- Supabase (CLIENT — exposto ao browser) --------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# -------- Supabase (SERVER ONLY — nunca exponha) --------
SUPABASE_SERVICE_ROLE_KEY=

# -------- App --------
VITE_APP_URL=http://localhost:3000
NODE_ENV=development

# -------- Evolution API / WhatsApp (SERVER ONLY) --------
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=
EVOLUTION_WEBHOOK_SECRET=

# -------- IA / OpenAI (SERVER ONLY) --------
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# -------- Seguranca --------
RATE_LIMIT_PUBLIC_PER_MINUTE=10