/* ============================================================
 * Ruah Barber Lounge — Base UI Styles
 * Importado em: src/routes/__root.tsx (via ?url import)
 * ============================================================ */

/* ============================================================
 * 1. Container
 * ============================================================ */
.theme-dark .ruah-container {
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: 1.25rem;
}

@media (min-width: 768px) {
  .theme-dark .ruah-container { padding-inline: 2rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-container { padding-inline: 3rem; }
}

/* ============================================================
 * 2. Section
 * ============================================================ */
.theme-dark .ruah-section {
  position: relative;
  padding-block: 3rem;
  background-color: var(--color-bg);
}

@media (min-width: 768px) {
  .theme-dark .ruah-section { padding-block: 6rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-section { padding-block: 8rem; }
}

.theme-dark .ruah-section--alt { background-color: var(--color-surface); }
.theme-dark .ruah-section--dark { background-color: var(--color-surface-dark); }

/* ============================================================
 * 3. Section Label
 * ============================================================ */
.theme-dark .ruah-section-label {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  font-family: var(--font-body);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--color-accent);
  margin-bottom: 1rem;
}

.theme-dark .ruah-section-label::before {
  content: '';
  width: 2rem;
  height: 1px;
  background-color: var(--color-accent);
  display: inline-block;
}

/* ============================================================
 * 4. Eyebrow
 * ============================================================ */
.theme-dark .ruah-eyebrow {
  width: 3rem;
  height: 2px;
  background-color: var(--color-accent);
  border: none;
  margin: 0 0 1.5rem 0;
}

.theme-dark .ruah-eyebrow--center { margin-inline: auto; }

/* ============================================================
 * 5. Botões
 * ============================================================ */
.theme-dark .ruah-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding: 0.875rem 2rem;
  border-radius: var(--radius-button);
  border: 1px solid transparent;
  cursor: pointer;
  transition: all 0.25s ease;
  text-decoration: none;
  white-space: nowrap;
  user-select: none;
}

.theme-dark .ruah-btn:focus-visible {
  outline: 2px solid var(--color-border-accent);
  outline-offset: 3px;
}

.theme-dark .ruah-btn--primary {
  background-color: var(--color-accent);
  color: var(--color-surface-dark);
  border-color: var(--color-accent);
}

.theme-dark .ruah-btn--primary:hover {
  background-color: var(--color-accent-hover);
  border-color: var(--color-accent-hover);
  transform: translateY(-2px);
  color: var(--color-surface-dark);
}

.theme-dark .ruah-btn--ghost {
  background-color: transparent;
  color: var(--color-text-on-dark);
  border-color: var(--color-border-accent);
}

.theme-dark .ruah-btn--ghost:hover {
  background-color: var(--color-accent);
  color: var(--color-surface-dark);
  border-color: var(--color-accent);
  transform: translateY(-2px);
}

.theme-dark .ruah-btn--outline {
  background-color: transparent;
  color: var(--color-text-on-dark);
  border-color: var(--color-border);
}

.theme-dark .ruah-btn--outline:hover {
  border-color: var(--color-accent);
  color: var(--color-accent);
}

/* ============================================================
 * 6. Headings utilitários
 * ============================================================ */
.theme-dark .ruah-h-display { font-size: clamp(2.5rem, 6vw, 4.5rem); line-height: 1.05; }
.theme-dark .ruah-h-1 { font-size: clamp(2rem, 4.5vw, 3.25rem); line-height: 1.1; }
.theme-dark .ruah-h-2 { font-size: clamp(1.625rem, 3.5vw, 2.5rem); line-height: 1.15; }
.theme-dark .ruah-h-3 { font-size: clamp(1.25rem, 2.5vw, 1.5rem); line-height: 1.25; }

/* ============================================================
 * 7. Texto auxiliar
 * ============================================================ */
.theme-dark .ruah-text-muted { color: var(--color-text-muted); }
.theme-dark .ruah-text-on-dark { color: var(--color-text-on-dark); }
.theme-dark .ruah-text-on-dark-muted { color: var(--color-text-on-dark-muted); }
.theme-dark .ruah-text-lead { font-size: 1.125rem; line-height: 1.7; }

@media (min-width: 768px) {
  .theme-dark .ruah-text-lead { font-size: 1.25rem; }
}

/* ============================================================
 * 8. Grid utilitário
 * ============================================================ */
.theme-dark .ruah-grid {
  display: grid;
  gap: 1.5rem;
}

@media (min-width: 768px) {
  .theme-dark .ruah-grid { gap: 2rem; }
}

.theme-dark .ruah-grid--2,
.theme-dark .ruah-grid--3,
.theme-dark .ruah-grid--4 {
  grid-template-columns: 1fr;
}

@media (min-width: 640px) {
  .theme-dark .ruah-grid--2,
  .theme-dark .ruah-grid--4 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-grid--3 { grid-template-columns: repeat(3, 1fr); }
  .theme-dark .ruah-grid--4 { grid-template-columns: repeat(4, 1fr); }
}

/* ============================================================
 * 9. Hero Section
 * ============================================================ */
.theme-dark .ruah-hero {
  position: relative;
  isolation: isolate;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  min-height: 100svh;
  overflow: hidden;
  background-color: var(--color-bg);
}

.theme-dark .ruah-hero::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent 0%, var(--color-accent) 50%, transparent 100%);
  opacity: 0.6;
  z-index: 2;
}

.theme-dark .ruah-hero::after {
  content: "";
  position: absolute;
  left: 0; right: 0; bottom: 0;
  height: 180px;
  background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0) 40%, var(--color-surface-dark) 100%);
  pointer-events: none;
  z-index: 2;
}

@media (max-width: 768px) {
  .theme-dark .ruah-hero::after { height: 120px; }
}

.theme-dark .ruah-hero__bg {
  position: absolute;
  inset: 0;
  z-index: -1;
  overflow: hidden;
}

.theme-dark .ruah-hero__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 1.2s ease-in-out;
  will-change: opacity;
}

.theme-dark .ruah-hero__slide--active { opacity: 1; }

.theme-dark .ruah-hero__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

@media (prefers-reduced-motion: reduce) {
  .theme-dark .ruah-hero__slide { transition: none; }
}

.theme-dark .ruah-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(8,6,4,0.88) 0%, rgba(20,14,8,0.65) 45%, rgba(30,20,10,0.25) 100%);
}

.theme-dark .ruah-hero__vignette {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at center, transparent 0%, rgba(10,6,2,0.45) 100%);
}

.theme-dark .ruah-hero__content {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: 1.25rem;
  padding-block: 6rem;
}

@media (min-width: 768px) {
  .theme-dark .ruah-hero__content { padding-inline: 2rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-hero__content { padding-inline: 3rem; }
}

.theme-dark .ruah-hero__eyebrow {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 2rem;
  font-family: var(--font-heading);
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--color-accent);
}

.theme-dark .ruah-hero__eyebrow-line {
  display: inline-block;
  width: 3rem;
  height: 2px;
  background-color: var(--color-accent);
}

@media (min-width: 640px) {
  .theme-dark .ruah-hero__eyebrow { font-size: 0.875rem; }
}

.theme-dark .ruah-hero__headline {
  font-family: var(--font-display);
  color: var(--color-text-heading);
  font-weight: 700;
  line-height: 0.95;
  letter-spacing: 0.01em;
  text-transform: uppercase;
  margin: 0 0 1.75rem 0;
  font-size: clamp(3.5rem, 10vw, 7.5rem);
  max-width: 100%;
}

.theme-dark .ruah-hero__headline-line { display: block; }
.theme-dark .ruah-hero__headline-accent { color: var(--color-accent); display: block; }

.theme-dark .ruah-hero__subheadline {
  font-family: var(--font-body);
  color: var(--color-text-on-dark);
  opacity: 0.85;
  line-height: 1.65;
  margin: 0 0 2.5rem 0;
  max-width: 38rem;
  font-size: 1.05rem;
}

@media (min-width: 768px) {
  .theme-dark .ruah-hero__subheadline { font-size: 1.25rem; margin-bottom: 3rem; }
}

.theme-dark .ruah-hero__ctas {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 1rem;
}

@media (min-width: 640px) {
  .theme-dark .ruah-hero__ctas { flex-direction: row; align-items: center; }
}

.theme-dark .ruah-hero__ctas .ruah-btn {
  text-transform: none;
  letter-spacing: 0.02em;
  font-size: 0.95rem;
  padding: 1rem 2.25rem;
}

.theme-dark .ruah-hero__scroll {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--color-accent);
}

.theme-dark .ruah-hero__scroll-label {
  font-family: var(--font-heading);
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.25em;
  text-transform: uppercase;
}
/* ============================================================
 * 10. Header
 * ============================================================ */
.theme-dark .ruah-header {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 100;
  width: 100%;
  background-color: transparent;
  border-bottom: 1px solid transparent;
  transition: background-color 0.35s ease, border-color 0.35s ease, backdrop-filter 0.35s ease, padding 0.35s ease;
  padding-block: 1.25rem;
}

.theme-dark .ruah-header--scrolled {
  background-color: rgba(15, 22, 25, 0.85);
  border-bottom-color: rgba(212, 175, 55, 0.15);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  padding-block: 0.75rem;
}

.theme-dark .ruah-header__inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: 1.25rem;
}

@media (min-width: 768px) {
  .theme-dark .ruah-header__inner { padding-inline: 2rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-header__inner { padding-inline: 3rem; }
}

.theme-dark .ruah-header__logo {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  text-decoration: none;
  color: var(--color-text-on-dark);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.25rem;
  letter-spacing: 0.05em;
  text-transform: uppercase;
}

.theme-dark .ruah-header__logo-mark {
  color: var(--color-accent);
  font-size: 1.5rem;
  line-height: 1;
}

.theme-dark .ruah-header__nav {
  display: none;
  align-items: center;
  gap: 2.25rem;
}

@media (min-width: 1024px) {
  .theme-dark .ruah-header__nav { display: flex; }
}

.theme-dark .ruah-header__nav-link {
  position: relative;
  font-family: var(--font-body);
  font-size: 0.8125rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--color-text-on-dark);
  text-decoration: none;
  transition: color 0.25s ease;
  padding-block: 0.25rem;
}

.theme-dark .ruah-header__nav-link::after {
  content: '';
  position: absolute;
  left: 0; right: 0; bottom: -4px;
  height: 1px;
  background-color: var(--color-accent);
  transform: scaleX(0);
  transform-origin: center;
  transition: transform 0.25s ease;
}

.theme-dark .ruah-header__nav-link:hover { color: var(--color-accent); }
.theme-dark .ruah-header__nav-link:hover::after { transform: scaleX(1); }

.theme-dark .ruah-header__cta { display: none; }

@media (min-width: 1024px) {
  .theme-dark .ruah-header__cta { display: inline-flex; }
}

.theme-dark .ruah-header__burger {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.5rem;
  height: 2.5rem;
  background: transparent;
  border: 1px solid var(--color-border-accent);
  border-radius: 4px;
  color: var(--color-text-on-dark);
  cursor: pointer;
  transition: color 0.25s ease, border-color 0.25s ease;
}

.theme-dark .ruah-header__burger:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
}

@media (min-width: 1024px) {
  .theme-dark .ruah-header__burger { display: none; }
}

/* ============================================================
 * 11. Mobile Menu
 * ============================================================ */
.theme-dark .ruah-mobile-menu {
  position: fixed;
  inset: 0;
  z-index: 200;
  display: flex;
  flex-direction: column;
  background-color: var(--color-bg);
  padding: 1.5rem;
  transform: translateX(100%);
  transition: transform 0.35s ease;
  overflow-y: auto;
}

.theme-dark .ruah-mobile-menu--open { transform: translateX(0); }

.theme-dark .ruah-mobile-menu__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 3rem;
}

.theme-dark .ruah-mobile-menu__close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 2.5rem;
  height: 2.5rem;
  background: transparent;
  border: 1px solid var(--color-border-accent);
  border-radius: 4px;
  color: var(--color-text-on-dark);
  cursor: pointer;
}

.theme-dark .ruah-mobile-menu__close:hover {
  color: var(--color-accent);
  border-color: var(--color-accent);
}

.theme-dark .ruah-mobile-menu__nav {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
  margin-bottom: 3rem;
}

.theme-dark .ruah-mobile-menu__link {
  font-family: var(--font-display);
  font-size: 1.75rem;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--color-text-on-dark);
  text-decoration: none;
  transition: color 0.25s ease;
}

.theme-dark .ruah-mobile-menu__link:hover { color: var(--color-accent); }

.theme-dark .ruah-mobile-menu__cta { margin-top: auto; }

/* ============================================================
 * 12. About Section — foto Renato (mobile no topo, desktop à esquerda)
 * ============================================================ */
.theme-dark .ruah-about {
  position: relative;
  padding-block: 4rem;
  background-color: var(--color-surface-dark);
  overflow: hidden;
}

@media (min-width: 768px) {
  .theme-dark .ruah-about { padding-block: 6rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-about { padding-block: 8rem; }
}

/* Foto background — mobile (topo) */
.theme-dark .ruah-about::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 55%;
  background-image: url('/ruah/images/team/renato.jpg');
  background-size: cover;
  background-position: center 20%;
  background-repeat: no-repeat;
  z-index: 0;
  pointer-events: none;
}

/* Fade gradiente — mobile (vertical) */
.theme-dark .ruah-about::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 55%;
  background: linear-gradient(
    to bottom,
    rgba(15, 22, 25, 0.35) 0%,
    rgba(15, 22, 25, 0.55) 50%,
    rgba(15, 22, 25, 0.95) 85%,
    var(--color-surface-dark) 100%
  );
  z-index: 0;
  pointer-events: none;
}

/* Foto background — desktop (esquerda) */
@media (min-width: 1024px) {
  .theme-dark .ruah-about::before {
    top: 0; bottom: 0; left: 0; right: auto;
    width: 50%;
    height: 100%;
    background-position: center 25%;
  }

  .theme-dark .ruah-about::after {
    top: 0; bottom: 0; left: 0; right: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      rgba(15, 22, 25, 0) 0%,
      rgba(15, 22, 25, 0) 30%,
      rgba(15, 22, 25, 0.65) 50%,
      rgba(15, 22, 25, 0.95) 62%,
      var(--color-surface-dark) 72%
    );
  }
}

.theme-dark .ruah-about__container {
  position: relative;
  z-index: 1;
  width: 100%;
  max-width: 1200px;
  margin-inline: auto;
  padding-inline: 1.25rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
  align-items: center;
}

@media (min-width: 768px) {
  .theme-dark .ruah-about__container { padding-inline: 2rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-about__container {
    padding-inline: 3rem;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }
}

/* Espaço reservado em mobile pra foto respirar */
.theme-dark .ruah-about__spacer {
  height: 280px;
}

@media (min-width: 640px) {
  .theme-dark .ruah-about__spacer { height: 360px; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-about__spacer { display: none; }
}

.theme-dark .ruah-about__text {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

@media (min-width: 1024px) {
  .theme-dark .ruah-about__text { grid-column: 2 / 3; }
}

.theme-dark .ruah-about__media { display: none; }

/* ============================================================
 * 13. Services Section
 * ============================================================ */
.theme-dark .ruah-services {
  position: relative;
  padding-block: 4rem;
  background-color: var(--color-bg);
}

@media (min-width: 768px) {
  .theme-dark .ruah-services { padding-block: 6rem; }
}

@media (min-width: 1024px) {
  .theme-dark .ruah-services { padding-block: 8rem; }
}

.theme-dark .ruah-service-card {
  position: relative;
  display: flex;
  flex-direction: column;
  gap: 1rem;
  padding: 2rem;
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-card);
  transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
}

.theme-dark .ruah-service-card:hover {
  border-color: var(--color-accent);
  transform: translateY(-4px);
  box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
}

.theme-dark .ruah-service-card__icon {
  width: 3rem;
  height: 3rem;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--color-accent);
}

.theme-dark .ruah-service-card__title {
  font-family: var(--font-display);
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--color-text-heading);
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.theme-dark .ruah-service-card__description {
  color: var(--color-text-on-dark-muted);
  font-size: 0.9375rem;
  line-height: 1.6;
}

.theme-dark .ruah-service-card__price {
  margin-top: auto;
  color: var(--color-accent);
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 1.125rem;
}

/* ============================================================
 * 14. Progress / Scroll Bar global
 * ============================================================ */
.theme-dark .ruah-progress {
  position: fixed;
  top: 0; left: 0;
  height: 2px;
  background-color: var(--color-accent);
  z-index: 999;
  transition: width 0.1s linear;
}
